# Dependencies — container এ নতুন করে install হবে
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# Environment variables — secrets, image এ রাখা unsafe
.env
.env.local
.env.production

# Git files — container এ লাগবে না
.git
.gitignore

# Editor config — পুরোপুরি unnecessary
.vscode
.idea
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Docker নিজের files — recursive হওয়া ঠিক না
Dockerfile
docker-compose.yml
.dockerignore

# Logs — image heavy হয়
logs
*.log

# Test files — production image এ লাগবে না
*.test.js
*.spec.js
__tests__
coverage

# Build output (যদি আলাদা build step থাকে)
dist
build